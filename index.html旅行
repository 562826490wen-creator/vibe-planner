<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vibe Planner - 스마트 여행 일정 플래너</title>

    <!-- Tailwind CSS (CDN) -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Leaflet CSS (CDN) -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

    <!-- Custom Font (Pretendard) -->
    <style>
        @import url('https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css');

        body {
            font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: #F3F4F6;
            /* 라이트 그레이 배경 */
        }

        /* 왼쪽 리스트 스크롤바 미장센 */
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #F3F4F6;
        }

        ::-webkit-scrollbar-thumb {
            background: #D1D5DB;
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #9CA3AF;
        }

        /* 리플렛 지도 팝업 커스텀 스타일 */
        .leaflet-popup-content-wrapper {
            border-radius: 12px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            padding: 2px;
        }

        .leaflet-popup-content {
            font-family: inherit;
            margin: 12px;
        }

        .leaflet-container a.leaflet-popup-close-button {
            top: 10px;
            right: 10px;
            color: #9CA3AF;
        }

        .leaflet-container a.leaflet-popup-close-button:hover {
            color: #374151;
        }
    </style>
</head>

<body class="overflow-hidden">

    <!-- 레이아웃 컨테이너 -->
    <div class="flex flex-col md:flex-row h-screen">

        <!-- 왼쪽 패널 (일정 리스트) - 40% -->
        <div
            class="w-full md:w-[40%] h-[45vh] md:h-full bg-gray-100 p-6 md:p-8 flex flex-col z-10 shadow-2xl overflow-hidden relative border-r border-gray-200">

            <!-- 헤더 및 버튼 영역 -->
            <div class="flex-shrink-0">
                <div class="flex items-center mb-1">
                    <span class="text-3xl mr-3">✈️</span>
                    <h1 class="text-3xl font-extrabold text-gray-800 tracking-tight">Vibe <span
                            class="text-blue-500">Planner</span></h1>
                </div>
                <p class="text-gray-500 text-sm mb-6 ml-1 font-medium">스마트하고 깔끔하게 떠나는 나만의 여행 스케줄러</p>

                <button id="generateBtn"
                    class="w-full bg-blue-500 hover:bg-blue-600 active:bg-blue-700 text-white font-bold text-lg py-4 px-6 rounded-xl shadow-md hover:shadow-lg transition-all duration-300 transform hover:-translate-y-0.5 flex justify-center items-center gap-2 mb-6 focus:outline-none focus:ring-4 focus:ring-blue-300">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24"
                        stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                            d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                    오사카 3박 4일 일정 생성
                </button>
            </div>

            <!-- 스크롤 가능한 생성 카드 영역 -->
            <div id="itineraryList" class="flex-grow overflow-y-auto pr-3 space-y-2 pb-10">
                <!-- 초기 빈 화면 표시 -->
                <div class="h-full flex flex-col items-center justify-center text-gray-400 opacity-90" id="emptyState">
                    <div class="bg-gray-200 p-4 rounded-full mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-gray-500" fill="none"
                            viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                        </svg>
                    </div>
                    <p class="text-lg font-semibold text-gray-500">버튼을 눌러 일정을 생성해보세요</p>
                    <p class="text-sm mt-2 text-center text-gray-400 max-w-[200px]">오사카의 핵심 명소 10곳을 추천해드립니다.</p>
                </div>
            </div>
        </div>

        <!-- 오른쪽 패널 (전체 지도) - 60% -->
        <div class="w-full md:w-[60%] h-[55vh] md:h-full relative z-0 bg-gray-50">
            <div id="map" class="w-full h-full"></div>
        </div>
    </div>

    <!-- Leaflet JS (CDN) -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // === 오사카 3박 4일 일정 데이터 (10개 장소) ===
        const itineraryDays = [
            {
                day: 1,
                title: "1일차: 도착과 상업의 중심지 맛보기",
                spots: [
                    { id: "spot1", time: "14:00", name: "구로몬 시장", desc: "오사카의 부엌, 신선한 해산물과 다채로운 길거리 음식 탐방", lat: 34.6654, lng: 135.5068 },
                    { id: "spot2", time: "18:00", name: "도톤보리", desc: "화려한 네온사인과 글리코상 앞 필수 인증샷 찰칵!", lat: 34.6687, lng: 135.5013 }
                ]
            },
            {
                day: 2,
                title: "2일차: 역사와 낭만적인 스카이라인",
                spots: [
                    { id: "spot3", time: "10:00", name: "오사카성", desc: "아름다운 천수각과 역사 깊은 오사카의 상징적 랜드마크", lat: 34.6873, lng: 135.5262 },
                    { id: "spot4", time: "19:00", name: "우메다 스카이 빌딩", desc: "아찔한 공중정원 전망대에서 감상하는 환상적인 도심 야경", lat: 34.7053, lng: 135.4896 }
                ]
            },
            {
                day: 3,
                title: "3일차: 테마파크 어드벤처 & 바다의 신비",
                spots: [
                    { id: "spot5", time: "09:00", name: "유니버설 스튜디오 재팬", desc: "도착부터 설렘! 멈추지 않는 짜릿한 어트랙션의 세계", lat: 34.6654, lng: 135.4323 },
                    { id: "spot6", time: "18:00", name: "가이유칸 (해유관)", desc: "세계 최대 규모의 수족관 속 신비로운 고래상어 만나기", lat: 34.6545, lng: 135.4290 }
                ]
            },
            {
                day: 4,
                title: "4일차: 복고와 클래식, 여정의 마무리",
                spots: [
                    { id: "spot7", time: "10:00", name: "시텐노지", desc: "천년의 세월을 품은, 일본에서 제일 오래된 역사 깊은 사찰", lat: 34.6533, lng: 135.5165 },
                    { id: "spot8", time: "12:00", name: "텐노지 동물원", desc: "빌딩 숲 한가운데 자리잡은 도심 속 생태 동물원 산책", lat: 34.6508, lng: 135.5085 },
                    { id: "spot9", time: "14:00", name: "츠텐카쿠 & 신세카이", desc: "레트로 감성 골목 코스, 본고장의 바삭한 쿠시카츠 먹방", lat: 34.6525, lng: 135.5063 },
                    { id: "spot10", time: "16:00", name: "아베노 하루카스", desc: "오사카가 한눈에! 하루카스 300에서 압도적인 전망으로 마무리", lat: 34.6458, lng: 135.5140 }
                ]
            }
        ];

        // === 지도 초기화 ===
        const map = L.map('map', { zoomControl: false }).setView([34.6937, 135.5023], 12);

        // 줌 컨트롤 위치 우측 상단으로 이동 (좌측 리스트에 의해 가려지지 않도록)
        L.control.zoom({ position: 'topright' }).addTo(map);

        // 깔끔하고 모던한 지형도 BaseLayer 추가 (CartoDB Voyager)
        L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/">CARTO</a>',
            subdomains: 'abcd',
            maxZoom: 20
        }).addTo(map);

        const markerGroup = L.featureGroup().addTo(map);
        let markersMap = {}; // id를 통해 마커에 쉽게 접근하기 위한 Dictionary

        // 커스텀 마커 아이콘 생성 함수 (날짜 번호를 아이콘에 표시)
        const createCustomIcon = (dayNum) => {
            return L.divIcon({
                className: 'custom-day-icon',
                html: `
                    <div style="background-color: #3B82F6; color: white; width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; border: 3px solid white; box-shadow: 0 4px 6px rgba(0,0,0,0.3); font-size: 15px;">
                        ${dayNum}
                    </div>
                `,
                iconSize: [34, 34],
                iconAnchor: [17, 34],
                popupAnchor: [0, -34]
            });
        };

        // DOM Elements
        const generateBtn = document.getElementById('generateBtn');
        const itineraryList = document.getElementById('itineraryList');
        const emptyState = document.getElementById('emptyState');

        // === 일정 생성 로직 ===
        generateBtn.addEventListener('click', () => {
            // 빈 상태 이미지 제거
            if (emptyState) emptyState.remove();

            // 기존 리스트 및 지도 마커 초기화
            itineraryList.innerHTML = '';
            markerGroup.clearLayers();
            markersMap = {};

            // 데이터 순회 및 렌더링
            itineraryDays.forEach(dayInfo => {
                // 1) 날짜별 헤더 렌더링
                const dayHeader = document.createElement('div');
                dayHeader.className = 'mt-10 mb-4 first:mt-0 sticky top-0 z-20 pt-2 pb-2 bg-gray-100/95 backdrop-blur-sm';
                dayHeader.innerHTML = `
                    <div class="inline-flex items-center px-4 py-2 bg-white rounded-full shadow-sm border border-blue-100">
                        <span class="bg-blue-500 text-white text-xs font-bold px-2 py-1 rounded-full mr-2">Day ${dayInfo.day}</span>
                        <span class="text-gray-800 font-bold text-sm md:text-base">${dayInfo.title}</span>
                    </div>
                `;
                itineraryList.appendChild(dayHeader);

                // 2) 장소 카드 및 지도 마커 렌더링
                dayInfo.spots.forEach(spot => {
                    // 왼쪽 리스트에 카드 추가 (디자인 개선: 부드러운 그림자와 호버 이펙트)
                    const card = document.createElement('div');
                    card.className = "bg-white rounded-xl shadow-md p-5 mb-4 cursor-pointer border-l-4 border-transparent hover:border-blue-500 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 relative overflow-hidden group";

                    card.innerHTML = `
                        <!-- 미세한 배경 효과 -->
                        <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-blue-50 to-transparent rounded-bl-full opacity-0 group-hover:opacity-100 transition-opacity duration-500 ease-in-out pointer-events-none"></div>
                        
                        <div class="flex justify-between items-start mb-3 relative z-10">
                            <h3 class="font-bold text-lg text-gray-800 bg-clip-text group-hover:text-transparent group-hover:bg-gradient-to-r group-hover:from-blue-600 group-hover:to-blue-400 transition-colors">${spot.name}</h3>
                            <span class="bg-blue-50 text-blue-600 text-xs font-bold px-2.5 py-1.5 rounded-lg whitespace-nowrap border border-blue-100 transform group-hover:scale-105 transition-transform">${spot.time}</span>
                        </div>
                        <p class="text-gray-500 text-sm leading-relaxed relative z-10">${spot.desc}</p>
                    `;

                    card.onclick = () => focusOnMap(spot.id);
                    itineraryList.appendChild(card);

                    // 오른쪽에 표시할 팝업 컨텐츠
                    const popupContent = `
                        <div class="p-1 min-w-[200px]">
                            <div class="bg-blue-50 text-blue-600 text-xs font-bold px-2 py-1 rounded inline-block mb-3 border border-blue-100">Day ${dayInfo.day} · ${spot.time}</div>
                            <h4 class="font-extrabold text-gray-900 text-[15px] mb-1.5">${spot.name}</h4>
                            <p class="text-[13px] text-gray-600 m-0 leading-snug">${spot.desc}</p>
                        </div>
                    `;

                    // 지도에 마커 등록
                    const marker = L.marker([spot.lat, spot.lng], { icon: createCustomIcon(dayInfo.day) })
                        .bindPopup(popupContent, { offset: [0, -5], autoPanPadding: [50, 50] })
                        .addTo(markerGroup);

                    markersMap[spot.id] = marker;
                });
            });

            // 3) 모든 마커가 잘 보이도록 지도 시야 자동 조절
            const bounds = markerGroup.getBounds();
            // 패딩을 넉넉히 줘서 맨 위나 아래에 있는 마커가 잘리지 않게 함 (<50px>여백)
            map.fitBounds(bounds, { padding: [60, 60], maxZoom: 14, animate: true, duration: 1.2 });

            // 4) 로딩/성공 상태 반영 (버튼 UI 업데이트)
            generateBtn.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
                일정 생성 완료! (클릭 시 새로고침)
            `;
            generateBtn.className = "w-full bg-emerald-500 hover:bg-emerald-600 active:bg-emerald-700 text-white font-bold text-lg py-4 px-6 rounded-xl shadow-md transition-all duration-300 flex justify-center items-center gap-2 mb-6 focus:outline-none focus:ring-4 focus:ring-emerald-300";
        });

        // === 지도 포커싱 및 팝업 이벤트 ===
        function focusOnMap(spotId) {
            const targetMarker = markersMap[spotId];
            if (!targetMarker) return;

            const latLng = targetMarker.getLatLng();

            // Leaflet의 FlyTo 애니메이션을 사용하여 부드러운 카메라 무빙 적용
            map.flyTo(latLng, 16, {
                duration: 1.5,     // 비행 지속 시간
                easeLinearity: 0.2 // 곡선 애니메이션 가속도
            });

            // 이동 애니메이션이 끝난 후 해당 장소 정보 팝업(Information) 출력
            map.once('moveend', () => {
                targetMarker.openPopup();
            });
        }
    </script>
</body>

</html>